# EmailJS — Vite requires VITE_ prefix for all client-side env vars
# Get these from: https://www.emailjs.com/
#
#   Service ID  → Dashboard > Email Services > your Gmail service
#   Template ID → Dashboard > Email Templates > your template
#   Public Key  → Top-right avatar > Account > API Keys
#
# After editing this file, STOP and RESTART the dev server: npm run dev

VITE_EMAILJS_SERVICE_ID=service_npgk1oa
VITE_EMAILJS_TEMPLATE_ID=template_jfrkrrf
VITE_EMAILJS_PUBLIC_KEY=TFPECtIFr1g2HY7Pb
